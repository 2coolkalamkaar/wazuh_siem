<group name="kubernetes,app,">
  <!-- Klog Warning -->
  <rule id="100201" level="5">
    <decoded_as>fluent-bit</decoded_as>
    <field name="klog_level">W</field>
    <description>Kubernetes Cluster Warning</description>
  </rule>

  <!-- Klog Error/Fatal -->
  <rule id="100202" level="10">
    <decoded_as>fluent-bit</decoded_as>
    <field name="klog_level">E|F</field>
    <description>Kubernetes Cluster Error or Fatal</description>
    <group>k8s_error,</group>
  </rule>

  <!-- App JSON Error -->
  <rule id="100301" level="7">
    <decoded_as>fluent-bit</decoded_as>
    <field name="level" type="pcre2">(?i)error|fatal|err|critical</field>
    <description>Application Error (JSON)</description>
  </rule>

  <!-- App JSON Warning -->
  <rule id="100302" level="4">
    <decoded_as>fluent-bit</decoded_as>
    <field name="level" type="pcre2">(?i)warn|warning</field>
    <description>Application Warning (JSON)</description>
  </rule>

  <rule id="100303" level="7">
    <decoded_as>fluent-bit</decoded_as>
    <field name="severity" type="pcre2">(?i)error|fatal|err|critical</field>
    <description>Application Error (JSON severity)</description>
  </rule>

  <rule id="100304" level="4">
    <decoded_as>fluent-bit</decoded_as>
    <field name="severity" type="pcre2">(?i)warn|warning</field>
    <description>Application Warning (JSON severity)</description>
  </rule>
</group>
